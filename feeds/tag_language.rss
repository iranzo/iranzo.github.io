&lt;span class="n"&gt;text&lt;/span&gt;&lt;span class="o"&gt;.&lt;/span&gt;&lt;span class="n"&gt;append&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s2"&gt;"Il mio machina e piu veloce"&lt;/span&gt;&lt;span class="p"&gt;,)&lt;/span&gt;
